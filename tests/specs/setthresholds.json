[
  {
    "name": "/setthresholds shows current spam thresholds",
    "steps": [
      {
        "send": { "text": "/setthresholds" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Current spam thresholds:\n\nIdentical message repeats: 3\nFlood rate: 5\nFlood window (seconds): 10\nMin account age (hours): 48"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "setthresholds:show callback shows thresholds",
    "steps": [
      {
        "send": { "callback": "setthresholds:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Current spam thresholds:\n\nIdentical message repeats: 3\nFlood rate: 5\nFlood window (seconds): 10\nMin account age (hours): 48"
            }
          }
        ]
      }
    ]
  }
]
