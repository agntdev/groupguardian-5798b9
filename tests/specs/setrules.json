[
  {
    "name": "/setrules shows no rules when empty",
    "steps": [
      {
        "send": { "text": "/setrules" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No spam rules configured yet."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "setrules:show callback shows no rules when empty",
    "steps": [
      {
        "send": { "callback": "setrules:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "No spam rules configured yet."
            }
          }
        ]
      }
    ]
  }
]
